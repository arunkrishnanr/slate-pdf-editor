<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- Hardened-runtime entitlements for DIRECT (Developer ID + notarization) distribution.
     NOT sandbox entitlements — this build is for distribution outside the Mac App Store.
       * disable-library-validation: the app loads bundled third-party dylibs (Qt, PyMuPDF,
         OpenCV, and the Tesseract toolchain) that aren't signed by our Team ID.
       * allow-unsigned-executable-memory / allow-jit: required by the CPython runtime. -->
<plist version="1.0">
<dict>
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
</dict>
</plist>
